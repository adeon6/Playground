          </GuiSettings>
          <Properties>
            <Configuration>
              <Text>Reporting, prep, and append</Text>
              <Font name="Segoe UI" size="8.25" style="1" />
              <TextColor name="Black" />
              <FillColor name="White" />
              <Shape shape="3" />
              <Justification Justification="1" />
