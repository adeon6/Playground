        <Node ToolID="97">
          <GuiSettings Plugin="AlteryxGuiToolkit.TextBox.TextBox">
            <Position x="66" y="615" width="227" height="24" />
          </GuiSettings>
          <Properties>
            <Configuration>
              <Text>Data input, spatial, transform, and prep</Text>
              <Font name="Segoe UI" size="8.25" style="1" />
