        <Node ToolID="22">
          <GuiSettings Plugin="AlteryxBasePluginsGui.Formula.Formula">
            <Position x="500" y="285" />
          </GuiSettings>
          <Properties>
            <Configuration>
              <FormulaFields>
                <FormulaField field="RevenueNum" type="Double" size="255" expression="ToNumber([Revenue])" />
                <FormulaField field="UnitsNum" type="Int32" size="255" expression="ToNumber([Units])" />
                <FormulaField field="DaysToShipNum" type="Int32" size="255" expression="ToNumber([DaysToShip])" />
              </FormulaFields>
            </Configuration>
        <Annotation DisplayMode="0">
          <Name />
          <DefaultAnnotationText>Cast order numerics</DefaultAnnotationText>
          <Left value="False" />
        </Annotation>
          </Properties>
