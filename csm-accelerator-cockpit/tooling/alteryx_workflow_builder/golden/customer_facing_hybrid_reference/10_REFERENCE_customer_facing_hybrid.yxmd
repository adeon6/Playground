          </GuiSettings>
          <Properties>
            <Configuration>
              <OrderChanged value="False" />
              <CommaDecimal value="False" />
              <SelectFields>
                <SelectField field="OrderID" selected="True" />
                <SelectField field="CustomerID" selected="True" />
