    <Node ToolID="40">
      <GuiSettings Plugin="AlteryxGuiToolkit.ToolContainer.ToolContainer">
        <Position x="1090" y="285" width="575" height="400" />
      </GuiSettings>
      <Properties>
        <Configuration>
          <Caption>4. Score And Prioritize</Caption>
          <Style TextColor="#0b2140" FillColor="#fff3e6" BorderColor="#c66f19" Transparency="18" Margin="10" />
          <Disabled value="False" />
          <Folded value="False" />
        </Configuration>
        <Annotation DisplayMode="0">
          <Name />
          <DefaultAnnotationText></DefaultAnnotationText>
          <Left value="False" />
        </Annotation>
      </Properties>
      <ChildNodes>
        <Node ToolID="41">
          <GuiSettings Plugin="AlteryxBasePluginsGui.Formula.Formula">
            <Position x="1125" y="465" />
          </GuiSettings>
          <Properties>
            <Configuration>
              <FormulaFields>
                <FormulaField field="GrossMarginValue" type="Double" size="255" expression="[RevenueNum] * ToNumber([GrossMarginPct])" />
                <FormulaField field="LateFlag" type="Int32" size="255" expression="IIF([DaysToShipNum] &gt; ToNumber([TargetShipDays]), 1, 0)" />
                <FormulaField field="PriorityScore" type="Int32" size="255" expression="Round(([RevenueNum] / 500) + ([LateFlag] * 35) + IIF([StrategicFlagText] = &quot;Yes&quot;, 15, 0), 1)" />
                <FormulaField field="RecommendedAction" type="V_WString" size="96" expression="IIF([LateFlag]=1, &quot;Escalate fulfilment recovery&quot;, IIF([StrategicFlagText]=&quot;Yes&quot;, &quot;Protect strategic revenue&quot;, &quot;Monitor in next cycle&quot;))" />
              </FormulaFields>
            </Configuration>
        <Annotation DisplayMode="0">
          <Name />
          <DefaultAnnotationText>Score order risk</DefaultAnnotationText>
          <Left value="False" />
        </Annotation>
          </Properties>
          <EngineSettings EngineDll="AlteryxBasePluginsEngine.dll" EngineDllEntryPoint="AlteryxFormula" />
        </Node>
        <Node ToolID="42">
          <GuiSettings Plugin="AlteryxSpatialPluginsGui.Summarize.Summarize">
            <Position x="1280" y="350" />
          </GuiSettings>
          <Properties>
            <Configuration>
              <SummarizeFields>
                <SummarizeField field="Region" action="GroupBy" rename="Region" />
                <SummarizeField field="Category" action="GroupBy" rename="Category" />
                <SummarizeField field="OrderID" action="Count" rename="OrderCount" />
                <SummarizeField field="RevenueNum" action="Sum" rename="RevenueTotal" />
                <SummarizeField field="UnitsNum" action="Sum" rename="UnitsTotal" />
                <SummarizeField field="DaysToShipNum" action="Avg" rename="AvgDaysToShip" />
                <SummarizeField field="LateFlag" action="Sum" rename="LateOrderCount" />
                <SummarizeField field="GrossMarginValue" action="Sum" rename="MarginValue" />
              </SummarizeFields>
            </Configuration>
        <Annotation DisplayMode="0">
          <Name />
          <DefaultAnnotationText>Regional category rollup</DefaultAnnotationText>
          <Left value="False" />
        </Annotation>
          </Properties>
          <EngineSettings EngineDll="AlteryxSpatialPluginsEngine.dll" EngineDllEntryPoint="AlteryxSummarize" />
        </Node>
        <Node ToolID="43">
          <GuiSettings Plugin="AlteryxBasePluginsGui.Formula.Formula">
            <Position x="1425" y="350" />
          </GuiSettings>
          <Properties>
            <Configuration>
              <FormulaFields>
                <FormulaField field="OnTimeRate" type="Double" size="255" expression="1 - ([LateOrderCount] / [OrderCount])" />
                <FormulaField field="PriorityScore" type="Int32" size="255" expression="Round(([RevenueTotal] / 1000) + ([LateOrderCount] * 20), 1)" />
                <FormulaField field="ReviewNote" type="V_WString" size="128" expression="IIF([LateOrderCount] &gt; 0, &quot;Review fulfilment and customer exposure&quot;, &quot;Healthy lane&quot;)" />
              </FormulaFields>
            </Configuration>
        <Annotation DisplayMode="0">
          <Name />
          <DefaultAnnotationText>Calculate KPI summary</DefaultAnnotationText>
          <Left value="False" />
        </Annotation>
          </Properties>
          <EngineSettings EngineDll="AlteryxBasePluginsEngine.dll" EngineDllEntryPoint="AlteryxFormula" />
        </Node>
        <Node ToolID="44">
          <GuiSettings Plugin="AlteryxBasePluginsGui.Sort.Sort">
            <Position x="1530" y="350" />
          </GuiSettings>
          <Properties>
            <Configuration>
              <SortInfo locale="0">
                <Field field="PriorityScore" order="Descending" />
                <Field field="RevenueTotal" order="Descending" />
              </SortInfo>
            </Configuration>
        <Annotation DisplayMode="0">
          <Name />
          <DefaultAnnotationText>Priority sort</DefaultAnnotationText>
          <Left value="False" />
        </Annotation>
          </Properties>
          <EngineSettings EngineDll="AlteryxBasePluginsEngine.dll" EngineDllEntryPoint="AlteryxSort" />
        </Node>
        <Node ToolID="45">
          <GuiSettings Plugin="AlteryxBasePluginsGui.Filter.Filter">
            <Position x="1425" y="580" />
          </GuiSettings>
          <Properties>
            <Configuration>
              <Expression>[PriorityScore] &gt;= 70 OR [LateFlag] = 1</Expression>
              <Mode>Custom</Mode>
            </Configuration>
        <Annotation DisplayMode="0">
          <Name />
          <DefaultAnnotationText>Find review queue</DefaultAnnotationText>
          <Left value="False" />
        </Annotation>
          </Properties>
          <EngineSettings EngineDll="AlteryxBasePluginsEngine.dll" EngineDllEntryPoint="AlteryxFilter" />
        </Node>
      </ChildNodes>
    </Node>
