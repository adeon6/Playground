        </Node>
        <Node ToolID="23">
          <GuiSettings Plugin="AlteryxBasePluginsGui.AlteryxSelect.AlteryxSelect">
            <Position x="340" y="415" />
          </GuiSettings>
          <Properties>
            <Configuration>
              <OrderChanged value="False" />
              <CommaDecimal value="False" />
              <SelectFields>
                <SelectField field="ProductID" selected="True" />
                <SelectField field="ProductName" selected="True" />
                <SelectField field="Category" selected="True" />
                <SelectField field="GrossMarginPct" selected="True" />
                <SelectField field="StrategicFlag" selected="True" />
                <SelectField field="*Unknown" selected="False" />
              </SelectFields>
            </Configuration>
        <Annotation DisplayMode="0">
          <Name />
          <DefaultAnnotationText>Keep product fields</DefaultAnnotationText>
          <Left value="False" />
        </Annotation>
          </Properties>
          <EngineSettings EngineDll="AlteryxBasePluginsEngine.dll" EngineDllEntryPoint="AlteryxSelect" />
        </Node>
        <Node ToolID="24">
          <GuiSettings Plugin="AlteryxBasePluginsGui.Formula.Formula">
            <Position x="500" y="415" />
          </GuiSettings>
          <Properties>
            <Configuration>
              <FormulaFields>
                <FormulaField field="MarginBand" type="V_WString" size="32" expression="IIF(ToNumber([GrossMarginPct]) &gt;= 0.35, &quot;Premium&quot;, IIF(ToNumber([GrossMarginPct]) &gt;= 0.25, &quot;Standard&quot;, &quot;Thin&quot;))" />
                <FormulaField field="StrategicFlagText" type="V_WString" size="8" expression="IIF([StrategicFlag] = &quot;Y&quot;, &quot;Yes&quot;, &quot;No&quot;)" />
              </FormulaFields>
            </Configuration>
        <Annotation DisplayMode="0">
          <Name />
          <DefaultAnnotationText>Classify margin</DefaultAnnotationText>
          <Left value="False" />
        </Annotation>
          </Properties>
          <EngineSettings EngineDll="AlteryxBasePluginsEngine.dll" EngineDllEntryPoint="AlteryxFormula" />
        </Node>
        <Node ToolID="25">
          <GuiSettings Plugin="AlteryxBasePluginsGui.AlteryxSelect.AlteryxSelect">
