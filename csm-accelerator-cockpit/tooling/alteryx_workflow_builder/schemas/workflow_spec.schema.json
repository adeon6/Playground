{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/alteryx/workflow_spec.schema.json",
  "title": "Alteryx Workflow Spec",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "goal",
    "inputs",
    "steps",
    "outputs",
    "assumptions",
    "metadata"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "type"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "enum": ["csv", "file", "db", "parquet", "json", "other"]
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "connection": {
            "type": "string",
            "minLength": 1
          },
          "fields": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "anyOf": [
          {
            "required": ["path"]
          },
          {
            "required": ["connection"]
          }
        ]
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "op", "args"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "op": {
            "type": "string",
            "enum": [
              "csv_input",
              "file_input",
              "db_input",
              "select",
              "cleanse",
              "formula",
              "filter",
              "join",
              "union",
              "summarize",
              "sort",
              "unique",
              "output_file",
              "output_db",
              "macro_call",
              "python_script"
            ]
          },
          "args": {
            "type": "object",
            "additionalProperties": true
          },
          "depends_on": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "outputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "format"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["file", "db", "report", "other"]
          },
          "format": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "connection": {
            "type": "string",
            "minLength": 1
          }
        },
        "anyOf": [
          {
            "required": ["path"]
          },
          {
            "required": ["connection"]
          }
        ]
      }
    },
    "app_params": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "type"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "enum": ["string", "int", "float", "bool", "date"]
          },
          "default": {},
          "description": {
            "type": "string"
          }
        }
      }
    },
    "assumptions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["author", "version"],
      "properties": {
        "author": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "designer_version": {
          "type": "string",
          "pattern": "^\\d{4}\\.\\d+$"
        }
      }
    }
  }
}
