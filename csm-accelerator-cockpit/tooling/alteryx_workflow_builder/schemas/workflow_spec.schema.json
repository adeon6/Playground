{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/alteryx/workflow_spec.schema.json",
  "title": "Alteryx Workflow Spec",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "goal",
    "inputs",
    "steps",
    "outputs",
    "assumptions",
    "metadata"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "type"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "enum": ["csv", "file", "db", "parquet", "json", "other"]
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "connection": {
            "type": "string",
            "minLength": 1
          },
          "fields": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "anyOf": [
          {
            "required": ["path"]
          },
          {
            "required": ["connection"]
          }
        ]
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "op", "args"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "op": {
            "type": "string",
            "enum": [
              "csv_input",
              "file_input",
              "db_input",
              "select",
              "cleanse",
              "formula",
              "filter",
              "join",
              "union",
              "summarize",
              "sort",
              "unique",
              "output_file",
              "output_db",
              "macro_call",
              "python_script",
              "datetime",
              "text_to_columns",
              "multi_row_formula",
              "cross_tab",
              "transpose",
              "sample",
              "data_cleansing",
              "record_id",
              "browse"
            ]
          },
          "args": {
            "type": "object",
            "additionalProperties": true
          },
          "depends_on": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "op": {
                  "enum": ["csv_input", "file_input", "output_file"]
                }
              }
            },
            "then": {
              "properties": {
                "args": {
                  "required": ["path"]
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "op": {
                  "enum": ["db_input", "output_db"]
                }
              }
            },
            "then": {
              "properties": {
                "args": {
                  "required": ["connection"]
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "op": {
                  "enum": ["formula", "cleanse"]
                }
              }
            },
            "then": {
              "properties": {
                "args": {
                  "oneOf": [
                    {
                      "required": ["formulas"]
                    },
                    {
                      "required": ["field", "expression"]
                    }
                  ]
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "op": {
                  "const": "filter"
                }
              }
            },
            "then": {
              "properties": {
                "args": {
                  "required": ["condition"]
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "op": {
                  "const": "summarize"
                }
              }
            },
            "then": {
              "properties": {
                "args": {
                  "anyOf": [
                    {
                      "required": ["group_by"]
                    },
                    {
                      "required": ["aggregations"]
                    }
                  ]
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "op": {
                  "const": "datetime"
                }
              }
            },
            "then": {
              "properties": {
                "args": {
                  "required": ["transformations"],
                  "properties": {
                    "transformations": {
                      "type": "array",
                      "minItems": 1,
                      "items": {
                        "type": "object",
                        "required": ["field", "output_field", "operation"],
                        "properties": {
                          "field": {
                            "type": "string",
                            "minLength": 1
                          },
                          "output_field": {
                            "type": "string",
                            "minLength": 1
                          },
                          "operation": {
                            "type": "string",
                            "minLength": 1
                          },
                          "input_format": {
                            "type": "string"
                          },
                          "output_format": {
                            "type": "string"
                          }
                        },
                        "additionalProperties": false
                      }
                    }
                  }
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "op": {
                  "const": "text_to_columns"
                }
              }
            },
            "then": {
              "properties": {
                "args": {
                  "required": ["field", "delimiter"]
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "op": {
                  "const": "multi_row_formula"
                }
              }
            },
            "then": {
              "properties": {
                "args": {
                  "required": ["field", "expression"]
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "op": {
                  "const": "cross_tab"
                }
              }
            },
            "then": {
              "properties": {
                "args": {
                  "required": ["group_by", "header_field", "data_field", "method"]
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "op": {
                  "const": "transpose"
                }
              }
            },
            "then": {
              "properties": {
                "args": {
                  "required": ["key_fields", "data_fields"]
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "op": {
                  "const": "sample"
                }
              }
            },
            "then": {
              "properties": {
                "args": {
                  "required": ["mode"],
                  "allOf": [
                    {
                      "if": {
                        "properties": {
                          "mode": {
                            "const": "first_n"
                          }
                        }
                      },
                      "then": {
                        "required": ["first_n"]
                      }
                    },
                    {
                      "if": {
                        "properties": {
                          "mode": {
                            "const": "random_n"
                          }
                        }
                      },
                      "then": {
                        "required": ["random_n"]
                      }
                    }
                  ]
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "op": {
                  "const": "data_cleansing"
                }
              }
            },
            "then": {
              "properties": {
                "args": {
                  "required": ["fields"],
                  "properties": {
                    "fields": {
                      "type": "array",
                      "minItems": 1
                    }
                  }
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "op": {
                  "const": "record_id"
                }
              }
            },
            "then": {
              "properties": {
                "args": {
                  "required": ["field_name"]
                }
              }
            }
          }
        ]
      }
    },
    "outputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "format"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["file", "db", "report", "other"]
          },
          "format": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "connection": {
            "type": "string",
            "minLength": 1
          }
        },
        "anyOf": [
          {
            "required": ["path"]
          },
          {
            "required": ["connection"]
          }
        ]
      }
    },
    "app_params": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "type"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "enum": ["string", "int", "float", "bool", "date"]
          },
          "default": {},
          "description": {
            "type": "string"
          }
        }
      }
    },
    "assumptions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["author", "version"],
      "properties": {
        "author": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "designer_version": {
          "type": "string",
          "pattern": "^\\d{4}\\.\\d+$"
        },
        "designer_profile": {
          "type": "string",
          "enum": ["2025.1", "2025.2"]
        },
        "mode": {
          "type": "string",
          "enum": ["starter_kit", "demo"]
        }
      }
    }
  }
}
