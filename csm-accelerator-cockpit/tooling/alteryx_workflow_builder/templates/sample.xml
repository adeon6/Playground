<Node ToolID="{{TOOL_ID}}">
  <GuiSettings Plugin="{{PLUGIN}}">
    <Position x="{{X}}" y="{{Y}}" />
  </GuiSettings>
  <Properties>
    <Configuration>
      <Mode>{{SAMPLE_MODE}}</Mode>
      <Value>{{SAMPLE_VALUE}}</Value>
      <Seed>{{SAMPLE_SEED}}</Seed>
      {{CONFIG_XML}}
    </Configuration>
    <Annotation DisplayMode="0">
      <Name>{{LABEL}}</Name>
    </Annotation>
  </Properties>
  <EngineSettings EngineDll="{{ENGINE_DLL}}" EngineDllEntryPoint="{{ENGINE_ENTRYPOINT}}" />
</Node>
