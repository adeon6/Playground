<Node ToolID="{{TOOL_ID}}">
  <GuiSettings Plugin="{{PLUGIN}}">
    <Position x="{{X}}" y="{{Y}}" />
  </GuiSettings>
  <Properties>
    <Configuration joinByRecordPos="False">
      {{JOIN_INFO}}
      <SelectConfiguration>
        <Configuration outputConnection="Join">
          <OrderChanged value="False" />
          <CommaDecimal value="False" />
          <SelectFields>
            {{JOIN_SELECT_FIELDS}}
          </SelectFields>
        </Configuration>
      </SelectConfiguration>
      {{CONFIG_XML}}
    </Configuration>
    <Annotation DisplayMode="0">
      <Name>{{LABEL}}</Name>
    </Annotation>
  </Properties>
  <EngineSettings EngineDll="{{ENGINE_DLL}}" EngineDllEntryPoint="{{ENGINE_ENTRYPOINT}}" />
</Node>
