<Node ToolID="{{TOOL_ID}}">
  <GuiSettings Plugin="{{PLUGIN}}">
    <Position x="{{X}}" y="{{Y}}" />
  </GuiSettings>
  <Properties>
    <Configuration>
      <Field>{{MRF_FIELD}}</Field>
      <Expression>{{MRF_EXPRESSION}}</Expression>
      <Rows>{{MRF_ROWS}}</Rows>
      <GroupBy>
        {{MRF_GROUP_BY}}
      </GroupBy>
      {{CONFIG_XML}}
    </Configuration>
    <Annotation DisplayMode="0">
      <Name>{{LABEL}}</Name>
    </Annotation>
  </Properties>
  <EngineSettings EngineDll="{{ENGINE_DLL}}" EngineDllEntryPoint="{{ENGINE_ENTRYPOINT}}" />
</Node>
