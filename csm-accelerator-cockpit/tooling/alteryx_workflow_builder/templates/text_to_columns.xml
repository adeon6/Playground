<Node ToolID="{{TOOL_ID}}">
  <GuiSettings Plugin="{{PLUGIN}}">
    <Position x="{{X}}" y="{{Y}}" />
  </GuiSettings>
  <Properties>
    <Configuration>
      <Field>{{TTC_FIELD}}</Field>
      <Delimiter>{{TTC_DELIMITER}}</Delimiter>
      <SplitToRows value="{{TTC_SPLIT_TO_ROWS}}" />
      <NumColumns>{{TTC_NUM_COLUMNS}}</NumColumns>
      {{CONFIG_XML}}
    </Configuration>
    <Annotation DisplayMode="0">
      <Name>{{LABEL}}</Name>
    </Annotation>
  </Properties>
  <EngineSettings EngineDll="{{ENGINE_DLL}}" EngineDllEntryPoint="{{ENGINE_ENTRYPOINT}}" />
</Node>
