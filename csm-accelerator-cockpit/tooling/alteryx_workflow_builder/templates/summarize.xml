<Node ToolID="{{TOOL_ID}}">
  <GuiSettings Plugin="AlteryxSpatialPluginsGui.Summarize.Summarize">
    <Position x="{{X}}" y="{{Y}}" />
  </GuiSettings>
  <Properties>
    <Configuration>
      <SummarizeFields>
        {{SUMMARIZE_FIELDS}}
      </SummarizeFields>
      {{CONFIG_XML}}
    </Configuration>
    <Annotation DisplayMode="0">
      <Name />
      <AnnotationText>{{LABEL}}</AnnotationText>
      <DefaultAnnotationText>{{LABEL}}</DefaultAnnotationText>
      <Left value="False" />
    </Annotation>
  </Properties>
  <EngineSettings EngineDll="AlteryxSpatialPluginsEngine.dll" EngineDllEntryPoint="AlteryxSummarize" />
</Node>
