<Node ToolID="{{TOOL_ID}}">
  <EngineSettings EngineDll="AlteryxBasePluginsEngine.dll" EngineDllEntryPoint="AlteryxDbFileInput" />
  <GuiSettings Plugin="AlteryxBasePluginsGui.DbFileInput.DbFileInput">
    <Position x="{{X}}" y="{{Y}}" />
  </GuiSettings>
  <Properties>
    <Configuration>
      <File SearchSubDirs="False" RecordLimit="" FileFormat="0">{{INPUT_PATH}}</File>
      <FormatSpecificOptions>
        <Delimeter>,</Delimeter>
        <FieldLen>254</FieldLen>
        <HeaderRow>True</HeaderRow>
      </FormatSpecificOptions>
      {{CONFIG_XML}}
    </Configuration>
    <Annotation DisplayMode="0">
      <Name />
      <DefaultAnnotationText>{{INPUT_PATH}}</DefaultAnnotationText>
      <Left value="False" />
    </Annotation>
  </Properties>
</Node>
