<Node ToolID="{{TOOL_ID}}">
  <GuiSettings Plugin="{{PLUGIN}}">
    <Position x="{{X}}" y="{{Y}}" />
  </GuiSettings>
  <Properties>
    <Configuration>
      <SortFields>
        {{SORT_FIELDS}}
      </SortFields>
      {{CONFIG_XML}}
    </Configuration>
    <Annotation DisplayMode="0">
      <Name>{{LABEL}}</Name>
    </Annotation>
  </Properties>
  <EngineSettings EngineDll="{{ENGINE_DLL}}" EngineDllEntryPoint="{{ENGINE_ENTRYPOINT}}" />
</Node>
