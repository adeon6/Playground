<Node ToolID="{{TOOL_ID}}">
  <GuiSettings Plugin="{{PLUGIN}}">
    <Position x="{{X}}" y="{{Y}}" />
  </GuiSettings>
  <Properties>
    <Configuration>
      <File MaxRecords="" FileFormat="0">{{OUTPUT_PATH}}</File>
      <Connection>{{CONNECTION_STRING}}</Connection>
      <Passwords />
      <Disable>False</Disable>
      <FormatSpecificOptions>
        <LineEndStyle>CRLF</LineEndStyle>
        <Delimeter>,</Delimeter>
        <ForceQuotes>False</ForceQuotes>
        <HeaderRow>True</HeaderRow>
        <CodePage>28591</CodePage>
        <WriteBOM>True</WriteBOM>
      </FormatSpecificOptions>
      <MultiFile value="False" />
      {{CONFIG_XML}}
    </Configuration>
    <Annotation DisplayMode="0">
      <Name>{{LABEL}}</Name>
    </Annotation>
  </Properties>
  <EngineSettings EngineDll="{{ENGINE_DLL}}" EngineDllEntryPoint="{{ENGINE_ENTRYPOINT}}" />
</Node>
