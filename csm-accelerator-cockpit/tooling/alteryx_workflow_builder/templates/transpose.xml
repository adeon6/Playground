<Node ToolID="{{TOOL_ID}}">
  <GuiSettings Plugin="{{PLUGIN}}">
    <Position x="{{X}}" y="{{Y}}" />
  </GuiSettings>
  <Properties>
    <Configuration>
      <KeyFields>
        {{TRANSPOSE_KEY_FIELDS}}
      </KeyFields>
      <DataFields>
        {{TRANSPOSE_DATA_FIELDS}}
      </DataFields>
      {{CONFIG_XML}}
    </Configuration>
    <Annotation DisplayMode="0">
      <Name>{{LABEL}}</Name>
    </Annotation>
  </Properties>
  <EngineSettings EngineDll="{{ENGINE_DLL}}" EngineDllEntryPoint="{{ENGINE_ENTRYPOINT}}" />
</Node>
